{
  "name": "health-sync-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create health-sync",
    "db:init": "wrangler d1 execute health-sync --remote --file=./schema.sql",
    "db:init-local": "wrangler d1 execute health-sync --local --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
